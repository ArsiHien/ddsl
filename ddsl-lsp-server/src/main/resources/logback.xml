<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="PROJECT_LOG_DIR" value="/home/ndhien/dev/ddsl/ddsl-lsp-server/logs"/>
    <property name="PROJECT_LOG_FILE" value="${PROJECT_LOG_DIR}/ddsl-lsp.log"/>

    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <file>${PROJECT_LOG_FILE}</file>
        <append>true</append>
        <prudent>true</prudent>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="FILE" />
    </root>
</configuration>